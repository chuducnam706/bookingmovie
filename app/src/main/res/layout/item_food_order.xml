<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/_8sdp"
    android:layout_marginBottom="@dimen/_12sdp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_14sdp">

        <!-- Rạp chiếu -->
        <TextView
            android:id="@+id/txtCinema"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawablePadding="8dp"
            android:text="CGV Vincom"
            android:textColor="#F59E0B"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold" />

        <!-- Thời gian đặt -->
        <TextView
            android:id="@+id/txtOrderTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="07/05/2025 12:00"
            android:textColor="#64748B"
            android:textSize="@dimen/_12ssp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#334155" />

        <!-- Danh sách món (nested RecyclerView) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/lstFoodItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#334155" />

        <!-- Tổng tiền -->
        <TextView
            android:id="@+id/txtTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tổng: 0đ"
            android:textAlignment="textEnd"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.cardview.widget.CardView>
